package JavaDay1;

public class FinalDemo {
    public static void main(String args[]) {
        final int i = 8;
        i++;
        System.out.println(i);
        Ball obj = new Ball();
        obj.show();
    }
}

class Cricket {
    public void show() {

        System.out.println("In a Parent");
    }
}

class Ball extends Cricket {
    public void show() {
        System.out.println("In a Child");//Method Overridding due to Polymorphism Concept
    }
}
