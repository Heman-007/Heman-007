public class Student
{
    public String name;//String is non primitive
    private int marks;

    public Student(String studName)//constructor
    {
        name=studName;
    }
    public void setMarks(int studMarks)//setter method syntax
    {
        marks=studMarks;
    }
     public void studentInfo()//
     {
         System.out.println("Name = "+ name);
         System.out.println("Marks= " +marks);
     }
     public static void main(String [] args)
     {
         Student s1=new Student ("Ankit");
         Student s2=new Student("Hemant");
         Student s3=new Student("Fatman");
         Student s4=new Student ("Shrivalli");

         s1.setMarks(98);
         s2.setMarks(100);
         s3.setMarks(65);
         s4.setMarks(50);

         s1.studentInfo();
         s2.studentInfo();
         s3.studentInfo();
         s4.studentInfo();


     }


}
