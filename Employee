public class Employee {
    int employeeid;
    String name;
    static String company = "Stark Industries";

    Employee(int employeeid, String name)
    {
        this.employeeid = employeeid;
        this.name = name;

    }

    void display() {
        System.out.println(employeeid + " " + name + " " + company);
    }

    public static void main(String args[]) {
        Employee e1 = new Employee(10, "Ankit");
        e1.display();
        Employee e2 = new Employee(11, "Himanshu");
        e2.display();
        Employee e3 = new Employee(12, "Abhi");
        e3.display();
    }

}
