package com.hemantsoft.java;
/**
 * Employees class
 */
 
public class Employees {
    int employeeId;
    String name;
    static String company = "Stark Industries";

    Employees(int employeeId, String name) {
        this.employeeId = employeeId;
        this.name = name;

    }

    void display() {
        System.out.println(employeeId + " " + name + " " + company);
    }

    public static void main(String args[]) {
        Employees employee1 = new Employees(10, "Ankit");
        employee1.display();
        Employees employee2 = new Employees(11, "Himanshu");
        employee2.display();
        Employees employee3 = new Employees(12, "Abhi");
        employee3.display();
    }

}
